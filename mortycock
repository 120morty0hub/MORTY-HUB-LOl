local function getInventoryText(player)
	local inventoryNames = {}

	if player.Backpack then
		for _, item in ipairs(player.Backpack:GetChildren()) do
			if item:IsA("Tool") then
				table.insert(inventoryNames, item.Name)
			end
		end
	end

	if player.Character then
		for _, item in ipairs(player.Character:GetChildren()) do
			if item:IsA("Tool") then
				table.insert(inventoryNames, item.Name)
			end
		end
	end

	return #inventoryNames > 0 and table.concat(inventoryNames, ", ") or "Ninguno"
end

local function updateESP(player)
	local character = player.Character
	if not character or not isValidTarget(character) then
		clearESP(player)
		return
	end

	local data = createESPForPlayer(player)
	if not data then
		return
	end

	local humanoid = character:FindFirstChildOfClass("Humanoid")
	local health = humanoid and humanoid.Health or 0

	data.Billboard.Enabled = espNameEnabled or espHealthEnabled or espDistanceEnabled or espBoxEnabled or espInventoryEnabled or hackerDetectionEnabled
	data.Box.Visible = espBoxEnabled
	data.NameLabel.Visible = espNameEnabled
	data.HealthLabel.Visible = espHealthEnabled
	data.DistanceLabel.Visible = espDistanceEnabled
	data.HackLabel.Visible = hackerDetectionEnabled
	data.InventoryLabel.Visible = espInventoryEnabled

	if espNameEnabled then
		data.NameLabel.Text = player.Name
	end

	if espHealthEnabled then
		data.HealthLabel.Text = "Vida: " .. math.floor(health)
	end

	if espDistanceEnabled then
		local distance = 0
		if LocalPlayer.Character and LocalPlayer.Character:FindFirstChild("HumanoidRootPart") and character:FindFirstChild("HumanoidRootPart") then
			distance = math.floor((LocalPlayer.Character.HumanoidRootPart.Position - character.HumanoidRootPart.Position).Magnitude)
		end
		data.DistanceLabel.Text = "Distancia: " .. distance
	end

	if hackerDetectionEnabled then
		local suspicious = false
		local humanoidRootPart = character:FindFirstChild("HumanoidRootPart")
		if humanoidRootPart then
			local speed = humanoid.WalkSpeed or 0
			local velocity = humanoidRootPart.Velocity.Magnitude
			if speed > 60 or velocity > 120 then
				suspicious = true
			end
		end
		if suspicious then
			data.HackLabel.Text = "Hacker Detected"
		else
			data.HackLabel.Text = ""
		end
	end

	if espInventoryEnabled then
		data.InventoryLabel.Text = "Inventario: " .. getInventoryText(player)
	end
end

