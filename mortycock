local function getLocalCharacter()
	return LocalPlayer and LocalPlayer.Character
end

local function isPickupCandidate(item)
	if item:IsA("Tool") and item.Parent and not item.Parent:IsDescendantOf(Players) then
		return true
	end
	if item:IsA("BasePart") and item.Name:lower():find("pickup") then
		return true
	end
	return false
end

local function findClosestPickup(character)
	local root = character:FindFirstChild("HumanoidRootPart") or character.PrimaryPart
	if not root then
		return nil
	end

	local bestTarget
	local bestDistance = autoPickupRange
	for _, item in ipairs(workspace:GetDescendants()) do
		if isPickupCandidate(item) then
			local handle = item:IsA("BasePart") and item or item:FindFirstChild("Handle") or item.PrimaryPart or item:FindFirstChildWhichIsA("BasePart")
			if handle and handle.Parent then
				local distance = (root.Position - handle.Position).Magnitude
				if distance < bestDistance then
					bestDistance = distance
					bestTarget = handle
				end
			end
		end
	end
	return bestTarget
end

local function doAutoPickup()
	if not autoPickupEnabled then
		return
	end

	local character = getLocalCharacter()
	if not character then
		return
	end

	local humanoid = character:FindFirstChildOfClass("Humanoid")
	local target = findClosestPickup(character)
	if target and humanoid and character.PrimaryPart then
		if (character.PrimaryPart.Position - target.Position).Magnitude > 4 then
			humanoid:MoveTo(target.Position)
		else
			character:SetPrimaryPartCFrame(CFrame.new(target.Position + Vector3.new(0, 3, 0)))
		end
	end
end

local function shouldAutoMinigameObject(obj)
	local name = obj.Name:lower()
	return name:find("atm") or name:find("fishing") or name:find("fish")
end

local function doAutoMinigame()
	if not autoMinigameEnabled then
		return
	end

	for _, obj in ipairs(workspace:GetDescendants()) do
		if obj:IsA("ProximityPrompt") and obj.Enabled and obj.Parent and shouldAutoMinigameObject(obj.Parent) then
			pcall(function()
				obj:InputHoldBegin()
				wait(0.2)
				obj:InputHoldEnd()
			end)
		end

		if obj:IsA("ClickDetector") and obj.Parent and shouldAutoMinigameObject(obj.Parent) then
			pcall(function()
				obj:FireClick(LocalPlayer)
			end)
		end
	end
end

