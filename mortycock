local function serializeConfig()
	local config = {
		silentAimEnabled = silentAimEnabled,
		fovSize = fovSize,
		meleeAuraEnabled = meleeAuraEnabled,
		autoAttackEnabled = autoAttackEnabled,
		bumpAuraEnabled = bumpAuraEnabled,
		safeFriend = safeFriend,
		antiKillEnabled = antiKillEnabled,
		antiRagdollEnabled = antiRagdollEnabled,
		antiLockEnabled = antiLockEnabled,
		highJumpEnabled = highJumpEnabled,
		infiniteStaminaEnabled = infiniteStaminaEnabled,
		invisibleEnabled = invisibleEnabled,
		hideNameEnabled = hideNameEnabled,
		enableSnapEnabled = enableSnapEnabled,
		snapDepth = snapDepth,
		enableGunMods = enableGunMods,
		weaponFireRate = weaponFireRate,
		weaponAccuracy = weaponAccuracy,
		weaponRecoil = weaponRecoil,
		weaponReloadTime = weaponReloadTime,
		weaponAutomatic = weaponAutomatic,
		espNameEnabled = espNameEnabled,
		espHealthEnabled = espHealthEnabled,
		espDistanceEnabled = espDistanceEnabled,
		espBoxEnabled = espBoxEnabled,
		espInventoryEnabled = espInventoryEnabled,
		hackerDetectionEnabled = hackerDetectionEnabled,
		droppedItemsEnabled = droppedItemsEnabled,
		autoPickupEnabled = autoPickupEnabled,
		autoMinigameEnabled = autoMinigameEnabled,
		autoPickupRange = autoPickupRange,
		spectateEnabled = spectateEnabled,
		spectateTarget = spectateTarget,
		skipCrateSpinEnabled = skipCrateSpinEnabled,
		fpsBoostEnabled = fpsBoostEnabled,
		gunAmmoType = gunAmmoType
	}
	
	local json = "{"
	local first = true
	for key, value in pairs(config) do
		if not first then json = json .. "," end
		first = false
		if type(value) == "string" then
			json = json .. '"' .. key .. '":"' .. tostring(value):gsub('"', '\\"') .. '"'
		else
			json = json .. '"' .. key .. '":' .. tostring(value)
		end
	end
	json = json .. "}"
	return json
end

