local function doMeleeAura()
	local character = getLocalCharacter()
	if not character or not meleeAuraEnabled then
		return
	end
	local targetPlayer = getClosestEnemy(10)
	local tool = getCurrentTool(character)
	if targetPlayer and tool then
		pcall(function()
			tool:Activate()
		end)
	end
end

local function doBumpAura()
	local character = getLocalCharacter()
	if not character then
		return
	end

	local root = character:FindFirstChild("HumanoidRootPart") or character.PrimaryPart
	if not root then
		return
	end

	for _, descendant in ipairs(workspace:GetDescendants()) do
		if descendant:IsA("BasePart") and descendant.Parent and descendant.Parent ~= character and not descendant:IsDescendantOf(Players) then
			local distance = (root.Position - descendant.Position).Magnitude
			if distance <= 12 then
				local bodyVelocity = Instance.new("BodyVelocity")
				bodyVelocity.MaxForce = Vector3.new(1e5, 1e5, 1e5)
				bodyVelocity.Velocity = (descendant.Position - root.Position).Unit * 80 + Vector3.new(0, 12, 0)
				bodyVelocity.P = 1e4
				bodyVelocity.Parent = descendant
				game:GetService("Debris"):AddItem(bodyVelocity, 0.12)
			end
		end
	end
end

local function doSnapUnderMap()
	local character = getLocalCharacter()
	if not character then
		return
	end
	local root = character:FindFirstChild("HumanoidRootPart") or character.PrimaryPart
	if root then
		root.CFrame = root.CFrame - Vector3.new(0, snapDepth, 0)
	end
end


