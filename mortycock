local function applyInfiniteStamina(character)
	if not character then
		return
	end

	local stamina = character:FindFirstChild("Stamina") or character:FindFirstChild("stamina")
	if stamina and stamina:IsA("NumberValue") then
		local maxVal = stamina:FindFirstChild("Max")
		if maxVal and maxVal:IsA("NumberValue") then
			stamina.Value = maxVal.Value
		else
			stamina.Value = 100
		end
	end
end

local function applyHighJump(character)
	local humanoid = character and character:FindFirstChildOfClass("Humanoid")
	if humanoid then
		if not originalJumpPower then
			originalJumpPower = humanoid.JumpPower
		end
		humanoid.UseJumpPower = true
		humanoid.JumpPower = 100
	end
end

local function restoreHighJump(character)
	local humanoid = character and character:FindFirstChildOfClass("Humanoid")
	if humanoid and originalJumpPower then
		humanoid.UseJumpPower = true
		humanoid.JumpPower = originalJumpPower
	end
end

local function getClosestEnemy(maxDistance)
	local localCharacter = getLocalCharacter()
	if not localCharacter then
		return nil
	end

	local bestTarget
	local bestDistance = maxDistance or 15
	local localRoot = localCharacter:FindFirstChild("HumanoidRootPart")
	if not localRoot then
		return nil
	end

	for _, player in ipairs(Players:GetPlayers()) do
		if player ~= LocalPlayer and player.Character and isValidTarget(player.Character) and player.Name ~= safeFriend then
			local targetRoot = player.Character:FindFirstChild("HumanoidRootPart") or player.Character:FindFirstChild("Head")
			if targetRoot then
				local distance = (localRoot.Position - targetRoot.Position).Magnitude
				if distance <= bestDistance then
					bestDistance = distance
					bestTarget = player
				end
			end
		end
	end

	return bestTarget
end

local function getCurrentTool(character)
	for _, item in ipairs(character:GetChildren()) do
		if item:IsA("Tool") then
			return item
		end
	end
	if LocalPlayer.Backpack then
		return LocalPlayer.Backpack:FindFirstChildWhichIsA("Tool")
	end
	return nil
end

local function applyGunModsToTool(tool)
	if not tool or not enableGunMods then
		return
	end

	local function setValue(prop, value)
		local child = tool:FindFirstChild(prop)
		if child and child:IsA("NumberValue") then
			child.Value = value
		end
		if tool[prop] ~= nil then
			pcall(function()
				tool[prop] = value
			end)
		end
		if tool:GetAttribute(prop) ~= nil then
			tool:SetAttribute(prop, value)
		end
	end

	setValue("FireRate", weaponFireRate)
	setValue("Accuracy", weaponAccuracy)
	setValue("Recoil", weaponRecoil)
	setValue("ReloadTime", weaponReloadTime)
	setValue("Automatic", weaponAutomatic)
end

local function doAutoAttack()
	local character = getLocalCharacter()
	if not character or not autoAttackEnabled then
		return
	end
	local targetPlayer = getClosestEnemy(50)
	local tool = getCurrentTool(character)
	if targetPlayer and tool then
		local humanoid = targetPlayer.Character:FindFirstChildOfClass("Humanoid")
		if humanoid and humanoid.Health > 0 then
			pcall(function()
				tool:Activate()
			end)
		end
	end
