	elseif lower:find("omega") then
		return text .. " [Omega]"
	elseif lower:find("epic") then
		return text .. " [Epic]"
	elseif lower:find("rare") then
		return text .. " [Rare]"
	elseif lower:find("money") or lower:find("dinero") then
