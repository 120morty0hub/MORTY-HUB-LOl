local function updateDroppedItems()
	if not droppedItemsEnabled then
		for item, _ in pairs(droppedItemObjects) do
			clearDroppedItem(item)
		end
		return
	end

	local seen = {}
	for _, item in ipairs(workspace:GetDescendants()) do
		if item:IsA("Tool") and item.Parent and not item.Parent:IsDescendantOf(Players) then
			local data = createDroppedItemESP(item)
			if data then
				data.Label.Text = getDroppedItemText(item)
				seen[item] = true
			end
		end
	end

	for item, _ in pairs(droppedItemObjects) do
		if not seen[item] or not item.Parent then
			clearDroppedItem(item)
		end
	end
end

