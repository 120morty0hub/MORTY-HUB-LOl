local function doSkipCrateSpin()
	if not skipCrateSpinEnabled then
		return
	end

	for _, obj in ipairs(workspace:GetDescendants()) do
		if obj:IsA("ProximityPrompt") then
			local text = (obj.ObjectText or ""):lower() .. " " .. (obj.ActionText or ""):lower()
			if text:find("spin") or text:find("crate") or text:find("abre") or text:find("open") then
				pcall(function()
					obj:InputHoldBegin()
					wait(0.1)
					obj:InputHoldEnd()
				end)
				break
			end
		end
	end
end

local function applyFPSBoost()
	if not fpsBoostEnabled then
		return
	end

	for _, part in ipairs(workspace:GetDescendants()) do
		if part:IsA("BasePart") then
			if part:FindFirstChild("SurfaceGui") then
				for _, gui in ipairs(part:FindFirstChild("SurfaceGui"):GetChildren()) do
					if gui:IsA("ParticleEmitter") or gui:IsA("Attachment") then
						pcall(function()
							gui:Destroy()
						end)
					end
				end
			end
		end

		if part:IsA("ParticleEmitter") then
			pcall(function()
				part.Enabled = false
			end)
		end
	end

	local lighting = game:GetService("Lighting")
	if lighting:FindFirstChild("Atmosphere") then
		pcall(function()
			lighting.Atmosphere.Density = 0
		end)
	end

	pcall(function()
		lighting.GlobalShadows = false
	end)
end

local function restoreFPSSettings()
	local lighting = game:GetService("Lighting")
	pcall(function()
		lighting.GlobalShadows = true
	end)
end

local function getAmmoNameFilters(selectedType)
	local lower = selectedType:lower()
	if lower:find("pistola") or lower:find("pistol") then
		return {"pistola", "pistol"}
	elseif lower:find("fusil") or lower:find("assault") or lower:find("rifle") then
		return {"fusil", "assault", "rifle"}
	elseif lower:find("escopeta") or lower:find("shotgun") then
		return {"escopeta", "shotgun"}
	elseif lower:find("especial") or lower:find("special") then
		return {"especial", "special", "unique"}
	end
	return {lower}
end

local function isNearGunStore(character)
	local root = character and (character:FindFirstChild("HumanoidRootPart") or character.PrimaryPart)
	if not root then
		return false
	end

	for _, part in ipairs(workspace:GetDescendants()) do
		if part:IsA("BasePart") then
			local text = part.Name:lower()
			if text:find("gun") or text:find("weapon") or text:find("ammo") or text:find("shop") then
				if (root.Position - part.Position).Magnitude <= 18 then
					return true
				end
			end
		end
	end
	return false
end

local function matchesAmmoBuyObject(text, filters)
	text = text:lower()
	for _, filter in ipairs(filters) do
		if text:find(filter) then
			if text:find("ammo") or text:find("balas") or text:find("crate") or text:find("buy") or text:find("comprar") or text:find("gun") then
				return true
			end
		end
	end
	return false
end

local function buyAmmoInGunStore()
	local character = getLocalCharacter()
	if not character then
		return
	end

	if not isNearGunStore(character) then
		return
	end

	local filters = getAmmoNameFilters(gunAmmoType)
	local found = false

	for _, obj in ipairs(workspace:GetDescendants()) do
		if obj:IsA("ProximityPrompt") and obj.Parent then
			local text = obj.Parent.Name:lower() .. " " .. (obj.ObjectText or ""):lower() .. " " .. (obj.ActionText or ""):lower()
			if matchesAmmoBuyObject(text, filters) then
				found = true
				pcall(function()
					obj:InputHoldBegin()
					wait(0.15)
					obj:InputHoldEnd()
				end)
				break
			end
		end

		if obj:IsA("ClickDetector") and obj.Parent then
			local text = obj.Parent.Name:lower() .. " " .. (obj.Name or ""):lower()
			if matchesAmmoBuyObject(text, filters) then
				found = true
				pcall(function()
					obj:FireClick(LocalPlayer)
				end)
				break
			end
		end
	end

	if not found then
		-- no se encontro boton de compra de municion
	end
end

local function applyAntiKill(character)
	local humanoid = character and character:FindFirstChildOfClass("Humanoid")
	if humanoid then
		if humanoid.Health > 0 and humanoid.Health < 20 then
			humanoid.Health = humanoid.MaxHealth or 100
		end
		if humanoid.MaxHealth and humanoid.MaxHealth < 100 then
			humanoid.MaxHealth = 100
		end
	end
end

local function applyAntiRagdoll(character)
	local humanoid = character and character:FindFirstChildOfClass("Humanoid")
	if humanoid then
		local state = humanoid:GetState()
		if state == Enum.HumanoidStateType.Physics or state == Enum.HumanoidStateType.FallingDown then
			humanoid:ChangeState(Enum.HumanoidStateType.RunningNoPhysics)
		end
	end
end

local function applyAntiLock(character)
	local humanoid = character and character:FindFirstChildOfClass("Humanoid")
	if humanoid then
		local state = humanoid:GetState()
		if state == Enum.HumanoidStateType.Seated or state == Enum.HumanoidStateType.PlatformStanding or state == Enum.HumanoidStateType.GettingUp then
			humanoid:ChangeState(Enum.HumanoidStateType.RunningNoPhysics)
		end
	end
end

local function setCharacterVisibility(character, visible)
	for _, part in ipairs(character:GetDescendants()) do
		if part:IsA("BasePart") then
			part.Transparency = visible and 0 or 1
			if part.Name ~= "HumanoidRootPart" then
				part.CanCollide = visible
			end
		elseif part:IsA("Decal") or part:IsA("Texture") then
			part.Transparency = visible and 0 or 1
		end
	end
end

local function restoreDisplayDistance(character)
	local humanoid = character and character:FindFirstChildOfClass("Humanoid")
	if humanoid and humanoid.DisplayDistanceType then
		humanoid.DisplayDistanceType = originalDisplayDistanceType
	end
end

local function applyHideName(character)
	local humanoid = character and character:FindFirstChildOfClass("Humanoid")
	if humanoid and humanoid.DisplayDistanceType then
		humanoid.DisplayDistanceType = Enum.HumanoidDisplayDistanceType.None
	end
